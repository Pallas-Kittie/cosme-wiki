    "inci_name_en": "Titanium Dioxide (Hydrated / Coated)",
    "inci_name_eu": "Titanium Dioxide",
    "name_zh": "二氧化钛（水合/涂层）",
    "common_name_en": "Titanium Dioxide (CI 77891) - Hydrated or Coated",
